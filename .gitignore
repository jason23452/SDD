# Runtime and dependency artifacts
node_modules/
**/node_modules/
**/.venv/
**/venv/
**/env/
.env
**/.env
**/.env.local
**/.env.*.local
!.env.example
!**/.env.example

# Build outputs
**/dist/
**/build/

# Test and tool caches
**/test-results/
**/coverage/
**/.pytest_cache/
**/.ruff_cache/
**/.pyright/
**/__pycache__/
**/*.py[cod]
**/*.tsbuildinfo

# OpenCode runtime recovery state
.opencode/run/
.opencode/run-artifacts/
.worktree/

# Local runtime data, logs, tmp and database files
**/*.log
**/logs/
**/tmp/
**/.tmp/
**/*.sqlite
**/*.sqlite3
**/*.db
**/test-results/
